{
  "name": "mimmi20/ua-comparator",
  "description": "a little project to compare different useragent parsers",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "Browser",
    "user agent",
    "http",
    "parser",
    "user-agent"
  ],
  "authors": [
    {
      "name": "Thomas Müller",
      "homepage": "https://github.com/mimmi20",
      "role": "Developer"
    },
    {
      "name": "Contributors",
      "homepage": "https://github.com/mimmi20/ua-comparator/graphs/contributors"
    }
  ],
  "homepage": "https://github.com/mimmi20/ua-comparator",
  "support": {
    "issues": "https://github.com/mimmi20/ua-comparator/issues",
    "source": "https://github.com/mimmi20/ua-comparator"
  },
  "require": {
    "php": "~8.5.0 || ~8.6.0",
    "ext-fileinfo": "*",
    "ext-intl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "composer-runtime-api": "^2.0",
    "browscap/browscap-php": "^7.7.1",
    "cbschuld/browser.php": "^2.0.0",
    "clue/framework-x": "^0.17.0",
    "devster/ubench": "^2.1.0",
    "donatj/phpuseragentparser": "^1.11.0",
    "endorphin-studio/browser-detector": "^6.0.1",
    "endorphin-studio/browser-detector-data": "^1.2.0",
    "foroco/php-browser-detection": "^2.8.0",
    "fyre/useragent": "^3.0.1",
    "guzzlehttp/guzzle": "^7.10.0",
    "guzzlehttp/psr7": "^2.9.0",
    "hassankhan/config": "^3.2.0",
    "hexydec/agentzero": "^2.0.3",
    "jaybizzle/crawler-detect": "^1.3.9",
    "laminas/laminas-config-aggregator": "^1.19.0",
    "laminas/laminas-serializer": "^3.3.0",
    "laminas/laminas-servicemanager": "^4.5.0",
    "league/flysystem": "^3.33.0",
    "league/flysystem-local": "^3.31.0",
    "matomo/device-detector": "^6.5.0",
    "matthiasmullie/scrapbook": "^1.5.4",
    "mimmi20/browscap-helper-source": "^6.0.2",
    "mimmi20/browser-detector": "^10.0.35",
    "mimmi20/browser-detector-version": "^13.0.3",
    "mimmi20/browser-detector-versioninterface": "^1.0.0",
    "mimmi20/monolog-callbackfilterhandler": "^4.0.2",
    "mimmi20/monolog-factory": "^5.0.4",
    "mimmi20/monolog-streamformatter": "^5.0.4",
    "mimmi20/ua-browser-type": "^12.0.1",
    "mimmi20/ua-data-mapper": "^6.0.0",
    "mimmi20/ua-result": "^15.0.2",
    "mobiledetect/mobiledetectlib": "^4.10.0",
    "monolog/monolog": "^3.10.0",
    "platine-php/user-agent": "^2.0.0",
    "psr/cache": "^3.0.0",
    "psr/container": "^1.1.2 || ^2.0.2",
    "psr/http-message": "^1.1 || ^2.0",
    "psr/log": "^3.0.2",
    "react/http": "^1.11.0",
    "symfony/console": "^7.3.6",
    "symfony/http-foundation": "^8.0.8",
    "ua-parser/uap-php": "^3.10.0",
    "whichbrowser/parser": "^2.1.8",
    "wolfcast/browser-detection": "^2.9.9",
    "woothee/woothee": "^1.10.0"
  },
  "require-dev": {
    "ext-ctype": "*",
    "ext-dom": "*",
    "ext-simplexml": "*",
    "ext-tokenizer": "*",
    "ext-xml": "*",
    "ext-xmlwriter": "*",
    "ergebnis/composer-normalize": "^2.51.0",
    "infection/infection": "^0.32.7",
    "jbelien/phpstan-sarif-formatter": "^1.2.0",
    "mimmi20/coding-standard": "^8.0.1",
    "nikic/php-parser": "^5.7.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.1.54",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "rector/rector": "^2.4.2",
    "rector/type-perfect": "^2.1.4",
    "shipmonk/composer-dependency-analyser": "^1.8.4",
    "symfony/process": "^8.0.8",
    "symplify/phpstan-rules": "^14.9.11",
    "tomasvotruba/cognitive-complexity": "^1.1.0",
    "tomasvotruba/type-coverage": "^2.1.0",
    "tomasvotruba/unused-public": "^2.2.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "UaComparator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "UaComparatorTest\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "infection/extension-installer": true,
      "phpstan/extension-installer": true
    },
    "lock": false,
    "preferred-install": {
      "browscap/browscap": "source",
      "donatj/phpuseragentparser": "source",
      "jaybizzle/crawler-detect": "source",
      "matomo/device-detector": "source",
      "mimmi20/browser-detector": "source",
      "mobiledetect/mobiledetectlib": "source",
      "whichbrowser/parser": "source",
      "woothee/woothee-testset": "source",
      "*": "dist"
    },
    "sort-packages": true
  },
  "extra": {
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    }
  }
}
